# ── Supabase PostgreSQL ──────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL : 트랜잭션 풀러(포트 6543) — 서버리스 런타임 쿼리용.
#                반드시 ?pgbouncer=true&connection_limit=1 파라미터를 유지할 것.
# DIRECT_URL   : 직접 연결(포트 5432) — prisma migrate 전용.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# ── Cron 보안 ────────────────────────────────────────────────────────
# GCP Cloud Scheduler가 /api/cron 호출 시 Authorization: Bearer <CRON_SECRET>
# 헤더로 보내야 하는 시크릿. 생성 예: openssl rand -hex 32
CRON_SECRET="replace-with-strong-random-secret"
