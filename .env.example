# ── Supabase PostgreSQL ──────────────────────────────────────────────
# Supabase Dashboard 상단 Connect 버튼 → 공유 풀러(IPv4) 주소 복사
#
# DATABASE_URL : 트랜잭션 풀러(포트 6543) — 서버리스 런타임 쿼리용.
#                반드시 ?pgbouncer=true&connection_limit=1 파라미터를 유지할 것
#                (connection_limit=1은 UI 기본 문자열에 없으므로 직접 추가).
# DIRECT_URL   : 세션 풀러(포트 5432) — prisma migrate 전용.
#                "Direct connection" 주소는 IPv6 전용이라 IPv4 환경에서는 세션 풀러 사용.
# 호스트의 aws-N-<region> 부분은 프로젝트 리전에 따라 다르다.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# ── Cron 보안 ────────────────────────────────────────────────────────
# GCP Cloud Scheduler가 /api/cron 호출 시 Authorization: Bearer <CRON_SECRET>
# 헤더로 보내야 하는 시크릿. 생성 예: openssl rand -hex 32
CRON_SECRET="replace-with-strong-random-secret"
